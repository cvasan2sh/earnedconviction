# The Forge — API Keys
# Copy this to .env and fill in your Anthropic key.

# Anthropic (Claude) — used by all agents
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override model for any agent
# Format: FORGE_MODEL_{AGENT_NAME}=provider:model
# Example: FORGE_MODEL_HISTORIAN=anthropic:claude-opus-4-6
